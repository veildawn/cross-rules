# =============================================
# Web3 规则集
# 适用于 mihomo (Clash.Meta)
# 更新日期: 2026-06-10
# =============================================

# =============================================
# Binance
# =============================================
DOMAIN-SUFFIX,binance.com

# =============================================
# Bybit
# =============================================
DOMAIN-SUFFIX,bybit.com
DOMAIN-SUFFIX,bybit.eu
DOMAIN-SUFFIX,bybit.id
DOMAIN-SUFFIX,bybit.kz
DOMAIN-SUFFIX,bybitglobal.com
PROCESS-NAME,com.bybit.app

# =============================================
# Bitget
# =============================================
DOMAIN-SUFFIX,bitget.com
DOMAIN-SUFFIX,bitgetapp.com
DOMAIN-SUFFIX,bitget.io

# =============================================
# SAVO - All-In-One Wallet
# =============================================
DOMAIN-SUFFIX,sv.me
DOMAIN-SUFFIX,savo.xyz

# =============================================
# Wise (TransferWise)
# =============================================
DOMAIN-SUFFIX,wise.com
DOMAIN-SUFFIX,transferwise.com

# =============================================
# 规则说明:
# - DOMAIN-SUFFIX: 匹配域名后缀
#
# 使用方式 (在 mihomo 配置中):
# rule-providers:
#   web3:
#     type: http
#     behavior: classical
#     url: "https://raw.githubusercontent.com/Ashbaer/cross-rules/main/mihomo/web3.list"
#     path: ./ruleset/web3.list
#     interval: 86400
#
# rules:
#   - RULE-SET,web3,代理策略组
# =============================================
